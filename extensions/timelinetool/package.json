{
    "package_version": 2,
    "version": "1.1.4",
    "name": "timelinetool",
    "description": "i18n:timelinetool.description",
    "main": "./dist/main.js",
    "devDependencies": {
        "@types/node": "^16.9.1",
        "typescript": "^4.3.4"
    },
    "author": "zongyoulin",
    "editor": ">=3.3.2",
    "contributions": {
        "asset-db": {
            "mount": {
                "path": "./assets",
                "readonly": true
            }
        },
        "menu": [
            {
                "path": "i18n:menu.extension",
                "label": "i18n:timelinetool.menu",
                "message": "open-scene"
            }
        ],
        "messages": {
            "open-scene": {
                "methods": [
                    "openScene"
                ]
            }
        }
    },
    "scripts": {
        "build": "tsc -b",
        "watch": "tsc -w"
    }
}